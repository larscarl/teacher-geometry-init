#!/bin/bash
# Slurm resources are intentionally provided via `sbatch ...` CLI.
# Example:
#   sbatch --time=12:00:00 --nodes=1 --ntasks=1 --mem=80G --partition=gpu_top --gres=gpu:1 --cpus-per-task=8 \
#     sbatchs/lmic_lm_eval_suite.submit --models ... --tasks ...
#SBATCH --account=cai_nlp
#SBATCH --output=logs/%j_%N__%x.out
#SBATCH --error=logs/%j_%N__%x.err

set -euo pipefail

# Slurm executes a temporary copy of this script from a spool directory.
# Use the submission directory to locate the repository and its `.env`.
REPO_ROOT="${SLURM_SUBMIT_DIR:-$(pwd)}"

# Load repo .env for CODE_DIRECTORY/HF_TOKEN/WANDB_*
if [[ -f "${REPO_ROOT}/.env" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${REPO_ROOT}/.env"
  set +a
fi

# CODE_DIRECTORY can be set in .env. Fall back to submit directory.
CODE_DIRECTORY="${CODE_DIRECTORY:-${REPO_ROOT}}"
if [[ "${CODE_DIRECTORY}" != /* ]]; then
  CODE_DIRECTORY="${REPO_ROOT}/${CODE_DIRECTORY}"
fi
if [[ ! -d "${CODE_DIRECTORY}" ]]; then
  echo "ERROR: CODE_DIRECTORY does not exist: ${CODE_DIRECTORY}" >&2
  exit 1
fi
cd "${CODE_DIRECTORY}"

# Bootstrap project environment on compute node.
if [[ ! -f "${CODE_DIRECTORY}/cluster/env_bootstrap.sh" ]]; then
  echo "ERROR: Missing bootstrap script: ${CODE_DIRECTORY}/cluster/env_bootstrap.sh" >&2
  exit 1
fi
# shellcheck disable=SC1091
source "${CODE_DIRECTORY}/cluster/env_bootstrap.sh"

# Re-load repo .env after bootstrap in case bootstrap changed environment.
if [[ -f "${CODE_DIRECTORY}/.env" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${CODE_DIRECTORY}/.env"
  set +a
fi

uv run python -m src.experiments.lm_eval_suite_runner "$@"

echo "=== lm-eval suite run completed ===" >&2
