# Hugging Face access token used by src/distillation/run_distill.py
HF_TOKEN=hf_xxx

# Weights & Biases API key (see https://wandb.ai/ to create a project + key)
WANDB_API_KEY=wandb_xxx
# Optional: override W&B project/entity for logging
WANDB_PROJECT=teacher-geometry-init
WANDB_ENTITY=
# Optional: enable W&B logging (or set wandb.enabled=true via overrides)
WANDB_ENABLED=false

# Absolute path to this repository (used by sbatchs/lmic_distill_hydra.submit)
CODE_DIRECTORY=/cluster/path/to/teacher-geometry-init
